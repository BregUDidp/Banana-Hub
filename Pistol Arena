        {"UpperTorso", "LeftUpperArm"}, {"LeftUpperArm", "LeftLowerArm"}, {"LeftLowerArm", "LeftHand"},
        {"UpperTorso", "RightUpperArm"}, {"RightUpperArm", "RightLowerArm"}, {"RightLowerArm", "RightHand"},
        {"LowerTorso", "LeftUpperLeg"}, {"LeftUpperLeg", "LeftLowerLeg"}, {"LeftLowerLeg", "LeftFoot"},
        {"LowerTorso", "RightUpperLeg"}, {"RightUpperLeg", "RightLowerLeg"}, {"RightLowerLeg", "RightFoot"}
    }

    for _, pair in ipairs(boneConnections) do
        local line = Drawing.new("Line")
        line.Thickness = 1.6
        line.Transparency = 0.85
        line.Visible = false
        table.insert(lines, { Line = line, Bone1 = pair[1], Bone2 = pair[2] })
    end

    ESP.SkeletonLines[player] = lines
end

local function RemoveSkeleton(player)
    if ESP.SkeletonLines[player] then
        for _, data in pairs(ESP.SkeletonLines[player]) do
            pcall(function() data.Line:Remove() end)
        end
        ESP.SkeletonLines[player] = nil
    end
end

--// ==================== MAIN LOOP ====================
RunService.RenderStepped:Connect(function()
    if not ESP.Enabled then
        for p in pairs(ESP.Boxes) do RemoveBoxESP(p) end
        for p in pairs(ESP.SkeletonLines) do RemoveSkeleton(p) end
        return
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            local root = character:FindFirstChild("HumanoidRootPart")
            local head = character:FindFirstChild("Head")

            if humanoid and root and humanoid.Health > 0 then
                local rootPos, onScreen = Camera:WorldToViewportPoint(root.Position)

                if onScreen then
                    CreateBoxESP(player)
                    local box = ESP.Boxes[player]

                    local distance = (Camera.CFrame.Position - root.Position).Magnitude
                    local scale = math.clamp(2000 / distance, 16, 240)
                    local size = Vector2.new(scale * 0.68, scale * 1.85)
                    local center = Vector2.new(rootPos.X, rootPos.Y)

                    local color = Rainbow(0)

                    -- Box + Shadow
                    box.Square.Size = size
                    box.Square.Position = center - size/2
                    box.Square.Color = color
                    box.Square.Visible = true

                    box.Shadow.Size = size + Vector2.new(4,4)
                    box.Shadow.Position = center - size/2 - Vector2.new(2,2)
                    box.Shadow.Visible = true

                    -- Name
                    box.Name.Position = center + Vector2.new(0, -size.Y/2 - 24)
                    box.Name.Text = player.DisplayName .. " [" .. math.floor(distance) .. "m]"
                    box.Name.Color = Rainbow(0.1)
                    box.Name.Visible = true

                    -- FPS บนหัว
                    if ESP.ShowFPS and head then
                        local headPos = Camera:WorldToViewportPoint(head.Position)
                        box.FPS.Position = Vector2.new(headPos.X, headPos.Y - 38)
                        box.FPS.Text = "FPS: " .. math.random(58, 62) -- จำลอง FPS (จริงๆ ควรคำนวณจาก heartbeat)
                        box.FPS.Visible = true
                    else
                        box.FPS.Visible = false
                    end

                    -- Tracer
                    if ESP.TracerEnabled then
                        local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y - 40)
                        box.Tracer.From = screenCenter
                        box.Tracer.To = Vector2.new(rootPos.X, rootPos.Y + size.Y/2 - 8)
                        box.Tracer.Color = color
                        box.Tracer.Visible = true
                    else
                        box.Tracer.Visible = false
                    end

                    -- Health Bar สวยขึ้น
                    local hpPercent = humanoid.Health / humanoid.MaxHealth
                    local barHeight = size.Y * hpPercent
                    
                    box.HealthBarOutline.Size = Vector2.new(6, size.Y + 2)
                    box.HealthBarOutline.Position = Vector2.new(center.X - size.X/2 - 11, center.Y - size.Y/2 - 1)
                    box.HealthBarOutline.Visible = true

                    box.HealthBar.Size = Vector2.new(4, barHeight)
                    box.HealthBar.Position = Vector2.new(center.X - size.X/2 - 10, center.Y - size.Y/2 + (size.Y - barHeight))
                    box.HealthBar.Color = Color3.fromHSV(hpPercent * 0.35, 1, 1)  -- สีแดง→เขียว
                    box.HealthBar.Visible = true

                else
                    RemoveBoxESP(player)
                end

                -- Skeleton
                if ESP.SkeletonEnabled then
                    CreateSkeleton(player)
                    local skel = ESP.SkeletonLines[player]
                    if skel then
                        for _, data in ipairs(skel) do
                            local part1 = character:FindFirstChild(data.Bone1)
                            local part2 = character:FindFirstChild(data.Bone2)
                            
                            if part1 and part2 then
                                local p1, vis1 = Camera:WorldToViewportPoint(part1.Position)
                                local p2, vis2 = Camera:WorldToViewportPoint(part2.Position)
                                
                                if vis1 and vis2 then
                                    data.Line.From = Vector2.new(p1.X, p1.Y)
                                    data.Line.To = Vector2.new(p2.X, p2.Y)
                                    data.Line.Color = Rainbow(0.25)
                                    data.Line.Visible = true
                                else
                                    data.Line.Visible = false
                                end
                            else
                                data.Line.Visible = false
                            end
                        end
                    end
                end

            else
                RemoveBoxESP(player)
                RemoveSkeleton(player)
            end
        else
            RemoveBoxESP(player)
            RemoveSkeleton(player)
        end
    end
end)

-- Cleanup
Players.PlayerRemoving:Connect(function(player)
    RemoveBoxESP(player)
    RemoveSkeleton(player)
end)

