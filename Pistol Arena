local RainbowSpeed = 1
local connections = {}

-- ฟังก์ชันสีรุ้ง
local function GetRainbowColor(offset)
    return Color3.fromHSV((tick() * RainbowSpeed + (offset or 0)) % 1, 1, 1)
end

-- สร้าง Rainbow Skeleton ESP (Highlight)
local function createRainbowSkeleton(character)
    if not character then return end
    
    -- ลบของเก่าถ้ามี
    if character:FindFirstChild("RainbowSkeletonESP") then
        character.RainbowSkeletonESP:Destroy()
    end
    
    local skeletonFolder = Instance.new("Folder")
    skeletonFolder.Name = "RainbowSkeletonESP"
    skeletonFolder.Parent = character
    
    local parts = {"Head", "HumanoidRootPart", "UpperTorso", "LowerTorso", "LeftUpperArm", "RightUpperArm", "LeftLowerArm", "RightLowerArm", "LeftHand", "RightHand", "LeftUpperLeg", "RightUpperLeg", "LeftLowerLeg", "RightLowerLeg", "LeftFoot", "RightFoot"}
    
    for _, partName in ipairs(parts) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            local highlight = Instance.new("Highlight")
            highlight.Name = "RainbowHighlight"
            highlight.FillColor = Color3.fromRGB(255, 255, 255)   -- จะเปลี่ยนทีหลัง
            highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
            highlight.FillTransparency = 0.35
            highlight.OutlineTransparency = 0.1
            highlight.Adornee = part
            highlight.Parent = skeletonFolder
        end
    end
end

local function removeRainbowSkeleton(character)
    if character and character:FindFirstChild("RainbowSkeletonESP") then
        character.RainbowSkeletonESP:Destroy()
    end
end

-- Main Loop สำหรับอัพเดทสีรุ้ง
RunService.RenderStepped:Connect(function()
    if not HitboxEnabled then return end
    
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character then
            local character = v.Character
            
            -- อัพเดทสีรุ้งให้ Highlight
            local folder = character:FindFirstChild("RainbowSkeletonESP")
            if folder then
                for _, highlight in pairs(folder:GetChildren()) do
                    if highlight:IsA("Highlight") then
                        local rainbow = GetRainbowColor()
                        highlight.FillColor = rainbow
                        highlight.OutlineColor = rainbow
                    end
                end
            end
            
            -- อัพเดท Hitbox
            pcall(function()
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.Size = Vector3.new(HeadSize, HeadSize, HeadSize)
                    hrp.Transparency = 0.65
                    hrp.Color = GetRainbowColor()
                    hrp.Material = Enum.Material.Neon
                    hrp.CanCollide = false
                end
            end)
        end
    end
end)

