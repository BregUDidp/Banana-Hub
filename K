local currentESPDrawings = {} -- สำหรับ Drawing (Box + Name) เฉพาะ ESP ปกติ
local espTargetPlayer = nil
local espConnection = nil

-- ฟังก์ชันสร้าง/อัปเดต Highlight
local function enableHighlight(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
   
    -- ลบ Highlight เก่า
    if currentESPHighlight and currentESPHighlight.Parent then
        currentESPHighlight:Destroy()
    end
   
    local highlight = Instance.new("Highlight")
    highlight.Parent = targetPlayer.Character
    highlight.FillColor = espFillColor
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = espOutlineColor
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Enabled = true
   
    currentESPHighlight = highlight
    espTargetPlayer = targetPlayer
end

-- ฟังก์ชันสร้าง Drawing ESP (Box + Name + Health)
local function enableDrawingESP(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
   
    -- ลบ Drawing เก่า
    for _, drawing in pairs(currentESPDrawings) do
        if drawing then drawing:Remove() end
    end
    currentESPDrawings = {}
   
    local box = Drawing.new("Square")
    box.Thickness = 2
    box.Filled = false
    box.Color = espFillColor
    box.Visible = false
   
    local nameText = Drawing.new("Text")
    nameText.Size = 16
    nameText.Center = true
    nameText.Outline = true
    nameText.Color = Color3.fromRGB(138, 43, 179)
    nameText.Visible = false
   
    currentESPDrawings = {Box = box, Name = nameText}
   
    -- อัปเดตทุกเฟรม
    if espConnection then espConnection:Disconnect() end
    espConnection = RunService.RenderStepped:Connect(function()
        if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") or not targetPlayer.Character:FindFirstChild("Head") or not targetPlayer.Character:FindFirstChild("Humanoid") then
            box.Visible = false
            nameText.Visible = false
            return
        end
       
        local root = targetPlayer.Character.HumanoidRootPart
        local head = targetPlayer.Character.Head
        local humanoid = targetPlayer.Character.Humanoid
       
        local screenPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(root.Position)
       
        if onScreen then
            local top = workspace.CurrentCamera:WorldToViewportPoint(head.Position + Vector3.new(0, 3, 0))
            local bottom = workspace.CurrentCamera:WorldToViewportPoint(head.Position - Vector3.new(0, 3, 0))
            local sizeY = (top - bottom).Magnitude
           
            box.Size = Vector2.new(sizeY * 2, sizeY * 3.5)
            box.Position = Vector2.new(screenPos.X - box.Size.X / 2, screenPos.Y - box.Size.Y / 2)
            box.Visible = true
           
            nameText.Text = targetPlayer.DisplayName .. " [ " .. math.floor(humanoid.Health) .. " ]"
            nameText.Position = Vector2.new(screenPos.X, screenPos.Y - box.Size.Y / 2 - 20)
            nameText.Visible = true
        else
            box.Visible = false
            nameText.Visible = false
        end
    end)
end

