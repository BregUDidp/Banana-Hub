-- Table สำหรับเก็บข้อมูล ESP ของแต่ละ player (รวมตัวเรา)
local PlayerESP = {}  -- [player] = {Highlight = ..., NameGui = ..., HealthConn = ..., ToolConnAdded = ..., ToolConnRemoved = ...}

-- ฟังก์ชันสร้าง/อัปเดต ESP สำหรับ player หนึ่งคน
local function UpdatePlayerESP(player)
    if not EspEnabled then return end
    
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local head = character:FindFirstChild("Head")
    if not head then return end
    
    local equippedTool = character:FindFirstChildOfClass("Tool")
    local toolName = equippedTool and equippedTool.Name or " ❌ "
    
    local hp = math.floor(humanoid.Health)
    local maxHp = math.floor(humanoid.MaxHealth)
    
    -- Highlight glow รอบตัว
    local espData = PlayerESP[player]
    if not espData then
        espData = {}
        PlayerESP[player] = espData
    end
    
    if not espData.Highlight then
        espData.Highlight = Instance.new("Highlight")
        espData.Highlight.Adornee = character
        espData.Highlight.FillColor = ESPColor
        espData.Highlight.OutlineColor = ESPColor
        espData.Highlight.FillTransparency = 0.5
        espData.Highlight.OutlineTransparency = 0
        espData.Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        espData.Highlight.Parent = character
    end
    
    -- BillboardGui บนหัว (แสดงทั้ง DisplayName และ Name)
    if not espData.NameGui then
        espData.NameGui = Instance.new("BillboardGui")
        espData.NameGui.Adornee = head
        espData.NameGui.Size = UDim2.new(0, 250, 0, 120)  -- ขยายให้พอใส่ 4 บรรทัดสบายๆ
        espData.NameGui.StudsOffset = Vector3.new(0, 3, 0)
        espData.NameGui.AlwaysOnTop = true
        espData.NameGui.Parent = head
        
        local text = Instance.new("TextLabel")
        text.Name = "InfoText"
        text.BackgroundTransparency = 1
        text.Size = UDim2.new(1, 0, 1, 0)
        text.TextColor3 = ESPColor
        text.TextStrokeTransparency = 0.3
        text.TextStrokeColor3 = Color3.new(0, 0, 0)
        text.Font = Enum.Font.GothamBold
        text.TextSize = 18
        text.TextYAlignment = Enum.TextYAlignment.Center
        text.Parent = espData.NameGui
    end
    
    if espData.NameGui:FindFirstChild("InfoText") then
        espData.NameGui.InfoText.Text = 
              player.DisplayName .. "\n" ..        -- ชื่อที่แสดงในเกม (ส่วนใหญ่เป็นชื่อเล่น)
            "( " .. player.Name .. " )\n" ..          -- Username จริง (อยู่ในวงเล็บ)
            "Items: " .. toolName .. "\n" ..
            "( HP: " .. hp .. "/" .. maxHp .. " )"
    end
end

-- ฟังก์ชันล้าง ESP ของ player
local function ClearPlayerESP(player)
    local espData = PlayerESP[player]
    if espData then
        if espData.Highlight then espData.Highlight:Destroy() end
        if espData.NameGui then espData.NameGui:Destroy() end
        if espData.HealthConn then espData.HealthConn:Disconnect() end
        if espData.ToolConnAdded then espData.ToolConnAdded:Disconnect() end
        if espData.ToolConnRemoved then espData.ToolConnRemoved:Disconnect() end
        PlayerESP[player] = nil
    end
end

-- ฟังก์ชันตั้งค่า ESP เมื่อ character โหลด
local function OnCharacterAdded(player, character)
    if not EspEnabled then return end
    
    -- อัปเดตทันที
    UpdatePlayerESP(player)
    
    -- เชื่อมต่อ event สำหรับอัปเดต realtime
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local espData = PlayerESP[player] or {}
        espData.HealthConn = humanoid.HealthChanged:Connect(function() UpdatePlayerESP(player) end)
        PlayerESP[player] = espData
    end
    
    -- เช็คการเปลี่ยน Tool
    local espData = PlayerESP[player] or {}
    espData.ToolConnAdded = character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then UpdatePlayerESP(player) end
    end)
    espData.ToolConnRemoved = character.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") then UpdatePlayerESP(player) end
    end)
    PlayerESP[player] = espData
end

-- เปิด ESP ทั้งหมด (รวมตัวเรา)
local function EnableESP()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character then
            OnCharacterAdded(player, player.Character)
        end
        player.CharacterAdded:Connect(function(char) OnCharacterAdded(player, char) end)
    end
    
    -- สำหรับ player ที่ join ใหม่
    Players.PlayerAdded:Connect(function(player)
        if EspEnabled then
            player.CharacterAdded:Connect(function(char) OnCharacterAdded(player, char) end)
            if player.Character then
                OnCharacterAdded(player, player.Character)
            end
        end
    end)
end

-- ปิด ESP ทั้งหมด
local function DisableESP()
    for _, player in pairs(Players:GetPlayers()) do
        ClearPlayerESP(player)
    end
end

espTab:CreateToggle({
    Name = "[ 💡 ]  ESP Character Player   [ - 138, 43, 179 - ]    [ - All - ]",
    CurrentValue = false,
    Callback = function(Value)
       EspEnabled = Value
        if Value then
            EnableESP()
        else
            DisableESP()
        end
    end,
})

