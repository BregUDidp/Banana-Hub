-- ===== ฟังก์ชันช่วย =====
local function getPlayerList()
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player then
            table.insert(list, string.format("%s (%s)", p.DisplayName, p.Name))
        end
    end
    table.sort(list)
    return list
end

local function getPlayerFromSelection(selected)
    if not selected or selected == "" then return nil end
    local friendName = selected:match("%((.-)%)") or selected
    return Players:FindFirstChild(friendName)
end

-- ฟังก์ชันเปิด ESP (ใช้สีปัจจุบัน)
local function enableESP(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then return end
    
    -- ลบ Highlight เก่าก่อน (กรณี respawn)
    if currentESPHighlight and currentESPHighlight.Parent then
        currentESPHighlight:Destroy()
    end
    local highlight = Instance.new("Highlight")
    highlight.Parent = targetPlayer.Character
    highlight.FillColor = espFillColor
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = espOutlineColor
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Enabled = true
    currentESPHighlight = highlight
    espTargetPlayer = targetPlayer
end

-- ฟังก์ชันปิด ESP
local function disableESP()
    if currentESPHighlight then
        currentESPHighlight:Destroy()
        currentESPHighlight = nil
    end
    if espConnection then
        espConnection:Disconnect()
        espConnection = nil
    end
    espTargetPlayer = nil
end

