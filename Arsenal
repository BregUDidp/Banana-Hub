local ESP = {
    Enabled = false,
    Tracer = true,
    SkeletonEnabled = false,     -- เปิด/ปิด ESP กระดูก
    TeamCheck = true,
    RainbowSpeed = 0.5,
    Boxes = {},
    SkeletonLines = {}           -- เก็บเส้นกระดูก
}

local function Rainbow(offset)
    return Color3.fromHSV((tick() * ESP.RainbowSpeed + (offset or 0)) % 1, 1, 1)
end

local function IsEnemy(player)
    if not ESP.TeamCheck then return true end
    if not LocalPlayer.Team or not player.Team then return true end
    return player.Team ~= LocalPlayer.Team
end

--// สร้างเส้นกระดูก
local function CreateSkeleton(player)
    if ESP.SkeletonLines[player] then return end
    
    local lines = {}
    local bones = {
        -- Head to Torso
        { "Head", "UpperTorso" },
        { "Head", "LowerTorso" },
        -- Arms
        { "UpperTorso", "LeftUpperArm" },
        { "LeftUpperArm", "LeftLowerArm" },
        { "LeftLowerArm", "LeftHand" },
        { "UpperTorso", "RightUpperArm" },
        { "RightUpperArm", "RightLowerArm" },
        { "RightLowerArm", "RightHand" },
        -- Legs
        { "LowerTorso", "LeftUpperLeg" },
        { "LeftUpperLeg", "LeftLowerLeg" },
        { "LeftLowerLeg", "LeftFoot" },
        { "LowerTorso", "RightUpperLeg" },
        { "RightUpperLeg", "RightLowerLeg" },
        { "RightLowerLeg", "RightFoot" }
    }

    for _, bonePair in ipairs(bones) do
        local line = Drawing.new("Line")
        line.Thickness = 1.8
        line.Transparency = 1
        line.Visible = false
        table.insert(lines, {Line = line, Bone1 = bonePair[1], Bone2 = bonePair[2]})
    end

    ESP.SkeletonLines[player] = lines
end

local function RemoveSkeleton(player)
    if ESP.SkeletonLines[player] then
        for _, data in pairs(ESP.SkeletonLines[player]) do
            pcall(function() data.Line:Remove() end)
        end
        ESP.SkeletonLines[player] = nil
    end
end

local function CreateESP(player)
    if ESP.Boxes[player] then return end
    
    local box = {}
    box.Square = Drawing.new("Square")
    box.Square.Thickness = 2
    box.Square.Filled = false
    box.Square.Visible = false

    box.Name = Drawing.new("Text")
    box.Name.Size = 16
    box.Name.Center = true
    box.Name.Outline = true
    box.Name.Visible = false

    box.Tracer = Drawing.new("Line")
    box.Tracer.Thickness = 2
    box.Tracer.Visible = false

    box.HealthBar = Drawing.new("Square")
    box.HealthBar.Thickness = 1
    box.HealthBar.Filled = true
    box.HealthBar.Visible = false

    ESP.Boxes[player] = box
end

local function RemoveESP(player)
    local box = ESP.Boxes[player]
    if box then
        for _, obj in pairs(box) do
            pcall(function() obj:Remove() end)
        end
        ESP.Boxes[player] = nil
    end
    RemoveSkeleton(player)
end

--// Main ESP Loop
RunService.RenderStepped:Connect(function()
    if not ESP.Enabled then
        for p, _ in pairs(ESP.Boxes) do RemoveESP(p) end
        return
    end

    for _, player in pairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end

        if not IsEnemy(player) then 
            RemoveESP(player)
            continue 
        end

        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local character = player.Character
            local humanoid = character:FindFirstChild("Humanoid")
            local root = character:FindFirstChild("HumanoidRootPart")

            if humanoid and root and humanoid.Health > 0 then
                CreateESP(player)
                local box = ESP.Boxes[player]

                local rootPos, onScreen = Camera:WorldToViewportPoint(root.Position)

                if onScreen then
                    local distance = (Camera.CFrame.Position - root.Position).Magnitude
                    local scale = math.clamp(2000 / distance, 18, 220)
                    local size = Vector2.new(scale * 0.65, scale * 1.8)
                    local center = Vector2.new(rootPos.X, rootPos.Y)

                    local boxColor = Rainbow(0)

                    -- Box + Name + Tracer + HealthBar (เหมือนเดิม)
                    box.Square.Size = size
                    box.Square.Position = center - size/2
                    box.Square.Color = boxColor
                    box.Square.Visible = true

                    box.Name.Position = center + Vector2.new(0, -size.Y/2 - 22)
                    box.Name.Text = player.DisplayName .. " [ENEMY]"
                    box.Name.Color = Color3.fromRGB(255, 60, 60)
                    box.Name.Visible = true

                    if ESP.Tracer then
                        local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y - 25)
                        box.Tracer.From = screenCenter
                        box.Tracer.To = Vector2.new(rootPos.X, rootPos.Y + size.Y/2 - 5)
                        box.Tracer.Color = boxColor
                        box.Tracer.Visible = true
                    else
                        box.Tracer.Visible = false
                    end

                    local hpPercent = humanoid.Health / humanoid.MaxHealth
                    local barHeight = size.Y * hpPercent
                    box.HealthBar.Size = Vector2.new(4, barHeight)
                    box.HealthBar.Position = Vector2.new(center.X - size.X/2 - 8, center.Y - size.Y/2 + (size.Y - barHeight))
                    box.HealthBar.Color = Color3.fromHSV(hpPercent * 0.33, 1, 1)
                    box.HealthBar.Visible = true

                    -- ==================== SKELETON ESP ====================
                    if ESP.SkeletonEnabled then
                        CreateSkeleton(player)
                        local skel = ESP.SkeletonLines[player]
                        if skel then
                            for _, data in ipairs(skel) do
                                local part1 = character:FindFirstChild(data.Bone1)
                                local part2 = character:FindFirstChild(data.Bone2)
                                
                                if part1 and part2 then
                                    local p1, vis1 = Camera:WorldToViewportPoint(part1.Position)
                                    local p2, vis2 = Camera:WorldToViewportPoint(part2.Position)
                                    
                                    if vis1 and vis2 then
                                        data.Line.From = Vector2.new(p1.X, p1.Y)
                                        data.Line.To = Vector2.new(p2.X, p2.Y)
                                        data.Line.Color = Rainbow(0.3)
                                        data.Line.Visible = true
                                    else
                                        data.Line.Visible = false
                                    end
                                else
                                    data.Line.Visible = false
                                end
                            end
                        end
                    else
                        RemoveSkeleton(player)
                    end

                else
                    -- ซ่อนเมื่อไม่อยู่ในจอ
                    if box then
                        box.Square.Visible = false
                        box.Name.Visible = false
                        box.Tracer.Visible = false
                        box.HealthBar.Visible = false
                    end
                    RemoveSkeleton(player)
                end
            else
                RemoveESP(player)
            end
        else
            RemoveESP(player)
        end
    end
end)

