-- ================== รับคำสั่งแชท ==================
player.Chatted:Connect(function(message)
	local msg = message:lower()
	local args = message:split(" ")
	
	if msg == "/fly" or msg:match("^/fly%s*%d*$") then
		local speed = msg:match("/fly%s*(%d+)")
		startFlying(speed)
		
	elseif msg == "/unfly" then
		stopFlying()
		
	elseif msg:match("^/speed%s*%d+$") then
		local speed = msg:match("/speed%s*(%d+)")
		setWalkSpeed(speed)
		
	elseif msg:match("^/jump%s*%d+$") then
		local power = msg:match("/jump%s*(%d+)")
		setJumpPower(power)
		
	elseif args[1]:lower() == "/tp" and args[2] then
		teleportToPlayer(args[2])
		
	elseif msg == "/rejoin" then
		rejoinServer()
		
	elseif msg == "/tooltp" then
		giveTeleportTool()
		
	elseif msg == "/toolrecoil" then
		giveRecoilTool()
		
	elseif msg == "/freeze" then
		freezePlayer()
		
	elseif msg == "/unfreeze" then
		unfreezePlayer()
	end
end)

-- เมื่อตัวละครเกิดใหม่
player.CharacterAdded:Connect(function(character)
	wait(0.5)
	if flying then stopFlying() end
	if isFrozen then
		isFrozen = false  -- รีเซ็ตสถานะเมื่อ respawn
	end
	
	local humanoid = character:WaitForChild("Humanoid")
	humanoid.WalkSpeed = originalWalkSpeed
	humanoid.JumpPower = originalJumpPower
end)

