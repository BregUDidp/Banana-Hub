	elseif msg == "/infinitejump" then
		enableInfiniteJump()
	elseif msg == "/uninfinitejump" then
		disableInfiniteJump()
	elseif msg == "/invisible" then
		makeInvisible()
	elseif msg == "/uninvisible" then
		makeVisible()
	elseif msg == "/infiniteyield" or msg == "/iy" then
		 loadInfiniteYield()
	end
end)

